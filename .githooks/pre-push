#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

branch=$(git symbolic-ref --short HEAD 2>/dev/null || true)

# fix_shas() {
#   bash "$ROOT/scripts/check-privilege-shas.sh" --update
# }
