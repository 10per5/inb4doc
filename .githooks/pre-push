#     jq --arg v "$target_ver" '.version = $v' editor/package.json > /tmp/pkg.json \
#       && mv /tmp/pkg.json editor/package.json
#   else
#     sed -i "s/\"version\": \".*\"/\"version\": \"$target_ver\"/" editor/package.json
#   fi
