<!doctype html>
<html lang="en" data-build-mode="<%= it.BUILD_MODE %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%~ include('partials/head-meta', it) %>
    <link rel="stylesheet" href="assets/katex.css" />
    <link rel="stylesheet" href="assets/app.css" />
    <%~ include('partials/loading-overlay-style', it) %>
  </head>
  <body>
    <%~ include('partials/loading-overlay', it) %>
    <div id="app" data-controller="shell" data-shell-editor-outlet="#editor-area">
      <div class="book-layout">
        <nav class="book-menu">
          <%~ include('partials/sidebar', it) %>
        </nav>
        <div class="book-content">
          <%~ include('partials/topbar', it) %>
          <div class="book-page">
            <div class="book-page-main">
              <%~ include('partials/editor-area', it) %>
            </div>
          </div>
        </div>
        <aside class="book-aside" id="meta-panel-mount" data-shell-target="metaPanel"></aside>
      </div>
    </div>
    <script type="module" src="assets/app.js"></script>
  </body>
</html>
